<Window x:Class="Task2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Countryside House" Height="600" Width="800"
        Background="#F0F0F0" ResizeMode="NoResize">

    <Grid>
        <Canvas x:Name="SceneContainer" 
                Width="800" Height="600"
                Background="Transparent"
                MouseLeftButtonDown="SceneContainer_MouseLeftButtonDown"
                MouseMove="SceneContainer_MouseMove"
                MouseLeftButtonUp="SceneContainer_MouseLeftButtonUp">

            <Rectangle Width="800" Height="600" Fill="#3b85cb"/>

            <Canvas Canvas.Left="620" Canvas.Top="50">
                <Ellipse Width="60" Height="60" Fill="#ffc64a"/>
                <Line X1="30" Y1="0" X2="30" Y2="-20" Stroke="#fff1a1" StrokeThickness="3"/>
                <Line X1="51" Y1="9" X2="65" Y2="-2" Stroke="#fff1a1" StrokeThickness="3"/>
                <Line X1="60" Y1="30" X2="75" Y2="30" Stroke="#fff1a1" StrokeThickness="3"/>
                <Line X1="51" Y1="51" X2="65" Y2="62" Stroke="#fff1a1" StrokeThickness="3"/>
                <Line X1="30" Y1="60" X2="30" Y2="80" Stroke="#fff1a1" StrokeThickness="3"/>
                <Line X1="9" Y1="51" X2="-5" Y2="62" Stroke="#fff1a1" StrokeThickness="3"/>
                <Line X1="0" Y1="30" X2="-15" Y2="30" Stroke="#fff1a1" StrokeThickness="3"/>
                <Line X1="9" Y1="9" X2="-5" Y2="-2" Stroke="#fff1a1" StrokeThickness="3"/>
            </Canvas>

            <Canvas Canvas.Left="50" Canvas.Top="100">
                <Ellipse Width="40" Height="30" Fill="#ffe1e1"/>
                <Ellipse Canvas.Left="25" Width="45" Height="35" Fill="#ffe1e1"/>
                <Ellipse Canvas.Left="20" Width="42" Height="32" Fill="#ffe1e1" Canvas.Top="-17"/>
                <Ellipse Canvas.Left="48" Width="38" Height="30" Fill="#ffe1e1" Canvas.Top="-7"/>
                <Ellipse Canvas.Left="35" Canvas.Top="12" Width="43" Height="33" Fill="#ffe1e1"/>
            </Canvas>

            <Canvas Canvas.Left="350" Canvas.Top="70">
                <Ellipse Width="40" Height="30" Fill="#ffe1e1"/>
                <Ellipse Canvas.Left="25" Width="45" Height="35" Fill="#ffe1e1"/>
                <Ellipse Canvas.Left="50" Width="42" Height="32" Fill="#ffe1e1"/>
                <Ellipse Canvas.Left="18" Width="38" Height="30" Fill="#ffe1e1" RenderTransformOrigin="-0.829,-0.015" Canvas.Top="-18"/>
                <Ellipse Canvas.Left="35" Canvas.Top="12" Width="43" Height="33" Fill="#ffe1e1"/>
            </Canvas>

            <Canvas Canvas.Left="600" Canvas.Top="90">
                <Ellipse Width="40" Height="30" Fill="#ffe1e1"/>
                <Ellipse Canvas.Left="25" Width="45" Height="35" Fill="#ffe1e1"/>
                <Ellipse Canvas.Left="40" Width="42" Height="32" Fill="#ffe1e1" Canvas.Top="-14"/>
                <Ellipse Canvas.Left="70" Width="38" Height="30" Fill="#ffe1e1"/>
                <Ellipse Canvas.Left="35" Canvas.Top="12" Width="43" Height="33" Fill="#ffe1e1"/>
            </Canvas>

            <Rectangle Canvas.Top="500" Width="800" Height="100" Fill="#317a1d"/>

            <Rectangle Canvas.Left="100" Canvas.Top="200" Width="400" Height="300" Fill="#d4a574"/>

            <Polygon Points="100,200 300,80 500,200" Fill="#B22222"/>

            <Rectangle Canvas.Left="380" Canvas.Top="60" Width="35" Height="120" Fill="#4c0b0b"/>

            <Rectangle Canvas.Left="140" Canvas.Top="280" Width="80" Height="100" 
                       Fill="#5db5e1" Stroke="#452f11" StrokeThickness="3"/>
            <Rectangle Canvas.Left="360" Canvas.Top="280" Width="80" Height="100" 
                       Fill="#5db5e1" Stroke="#452f11" StrokeThickness="3"/>

            <Canvas Canvas.Left="260" Canvas.Top="370">
                <Rectangle Width="80" Height="130" Fill="brown"/>
                <Ellipse Canvas.Left="65" Canvas.Top="60" Width="10" Height="10" Fill="gold"/>
            </Canvas>
            <Canvas Canvas.Left="0" Canvas.Top="470">
                <Rectangle Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="20" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="40" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="60" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="80" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="100" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="120" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="140" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="160" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="180" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="200" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="220" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="240" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="260" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="280" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="300" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="320" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="340" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="360" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="380" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="400" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="420" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="440" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="460" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="480" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="500" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="520" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="540" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="560" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="580" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="600" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="620" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="640" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="660" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="680" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="700" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="720" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="740" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="760" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Left="780" Width="8" Height="60" Fill="#5b3012"/>
                <Rectangle Canvas.Top="15" Width="800" Height="5" Fill="#7a4a28"/>
                <Rectangle Canvas.Top="40" Width="800" Height="5" Fill="#7a4a28"/>
            </Canvas>
        </Canvas>

        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5"
                   FontSize="12" Foreground="#333" FontStyle="Italic">
            Зажмите ЛКМ и перетащите сцену
        </TextBlock>
    </Grid>
</Window>