<Window x:Class="Task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" HorizontalAlignment="Center" VerticalAlignment="Center" ResizeMode="NoResize">
    <Grid>
        <!-- Основной контейнер для центрирования -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Буква M -->
            <Canvas x:Name="CanvasM" Width="70" Height="60" Margin="10,0">
                <Path Data="M 5,55 L 18,15 L 35,40 L 52,15 L 65,55" 
                      Stroke="Red" StrokeThickness="8" StrokeLineJoin="Round" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" 
                      Fill="Transparent" HorizontalAlignment="Center" Canvas.Left="16.998" VerticalAlignment="Top" Canvas.Top="10" Stretch="Fill" Width="63" Height="50"/>
            </Canvas>

            <!-- Буква P -->
            <Canvas x:Name="CanvasP" Width="50" Height="60" Margin="10,0">
                <Line X1="10" Y1="10" X2="10" Y2="55" 
                      Stroke="Green" StrokeThickness="8" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Canvas.Left="10" Canvas.Top="1"/>
                <Path Data="M 10,20 A 15,15 0 0 1 25,32 A 15,15 0 0 1 10,44" 
                      Stroke="Green" StrokeThickness="8" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" 
                      StrokeLineJoin="Round" Fill="Transparent" HorizontalAlignment="Center" Canvas.Top="6.6" VerticalAlignment="Top" Stretch="Fill" Width="30" Canvas.Left="15.5" Height="36"/>
            </Canvas>

            <!-- Буква Sh -->
            <Canvas x:Name="CanvasSh" Width="60" Height="60" Margin="10,0">
                <Line X1="10" Y1="15" X2="10" Y2="55" 
                      Stroke="Blue" StrokeThickness="8" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="30" Y1="15" X2="30" Y2="55" 
                      Stroke="Blue" StrokeThickness="8" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="50" Y1="15" X2="50" Y2="55" 
                      Stroke="Blue" StrokeThickness="8" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="10" Y1="15" X2="50" Y2="15" 
                      Stroke="Blue" StrokeThickness="8" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Center" Canvas.Top="41" VerticalAlignment="Top"/>
            </Canvas>

        </StackPanel>
    </Grid>
</Window>